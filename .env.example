# UniDisk configuration.
# Copy this file to ".env" (same folder as docker-compose.yml) and fill in.
# Docker Compose loads ".env" automatically. NEVER commit your real ".env".
#
# Everything here is optional except the admin credentials on first boot.

# ─── Host port ───────────────────────────────────────────────────────────────
# Port the app is published on. Defaults to 8080. Change if it's already taken.
UNIDISK_PORT=8080

# ─── Bootstrap administrator ─────────────────────────────────────────────────
# Seeded once, on first boot, when the database has no users. This is the ONLY
# way the first admin is created (there is no self-registration). Change the
# password before exposing the instance.
UNIDISK_ADMIN_EMAIL=admin@unidisk.local
UNIDISK_ADMIN_PASSWORD=changeme123

# ─── Session signing ─────────────────────────────────────────────────────────
# Long random string. If unset, a new one is generated each boot and all users
# are logged out on restart. Set this in production.
#   generate one with:  openssl rand -hex 32
UNIDISK_JWT_SECRET=

# ─── Encryption at rest ──────────────────────────────────────────────────────
# Encrypts provider credentials (refresh tokens, S3 keys) stored in the DB.
# Optional: if unset, a random key is generated once and persisted as
# <data>/unidisk.key. Set it to manage the key yourself (e.g. for backups /
# multiple replicas). Changing it makes existing accounts need reconnecting.
UNIDISK_ENCRYPTION_KEY=

# ─── Public URL ──────────────────────────────────────────────────────────────
# Optional. Leave empty to auto-detect from each request (works by IP, by DNS,
# and behind a reverse proxy via X-Forwarded-* headers). Set only to force a
# fixed URL, e.g. https://unidisk.example.com
UNIDISK_PUBLIC_URL=

# ─── Provider OAuth apps (for the one-click "Connect" flow) ───────────────────
# Each is optional — a provider's "Connect" button only appears once its app
# credentials are set. Register each app's redirect URI as:
#   <your-url>/api/oauth/<provider>/callback
# Providers without credentials here can still be added via their manual form.

# Google Drive — Google Cloud Console → APIs & Services → Credentials
UNIDISK_GOOGLE_CLIENT_ID=
UNIDISK_GOOGLE_CLIENT_SECRET=

# Dropbox — https://www.dropbox.com/developers/apps
UNIDISK_DROPBOX_APP_KEY=
UNIDISK_DROPBOX_APP_SECRET=

# OneDrive — Azure Portal → App registrations
UNIDISK_ONEDRIVE_CLIENT_ID=
UNIDISK_ONEDRIVE_CLIENT_SECRET=

# Box — https://app.box.com/developers/console
UNIDISK_BOX_CLIENT_ID=
UNIDISK_BOX_CLIENT_SECRET=

# pCloud — https://docs.pcloud.com/  (My Apps)
UNIDISK_PCLOUD_CLIENT_ID=
UNIDISK_PCLOUD_CLIENT_SECRET=

# S3-compatible (Amazon S3, Backblaze B2, Wasabi, Cloudflare R2, MinIO, …)
# needs no instance config — credentials are entered per-account in the UI.
